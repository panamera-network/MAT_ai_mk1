{
  "name": "mat-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "electron electron/main.ts",
    "build": "tsc --noEmit && vite build",
    "release": "electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^16.4.5",
    "node-audiorecorder": "^3.0.0",
    "node-record-lpcm16": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sherpa-onnx": "^1.13.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^2.0.3",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.13",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "build": {
    "appId": "com.matai.desktop",
    "productName": "MAT.ai",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
