# Copy this file to `.env` and fill in your values (never commit `.env`).

# MAT-AI-OS backend — the single brain for chat. Must be running before MK1 can chat;
# there is no fallback to a direct LLM call if it's unreachable.
MAT_OS_URL=http://localhost:8000

# Still needed: OpenAI Whisper for voice-to-text (core/voice/speechToText.ts). This is
# the ONLY thing this key is used for now — chat itself goes through MAT-AI-OS above.
OPENAI_API_KEY=sk-your-key-here

# Optional: hint language for Whisper (ISO-639-1), e.g. Malay
# OPENAI_TRANSCRIBE_LANGUAGE=ms

# Optional: auto-open DevTools in dev
# MAT_AI_OPEN_DEVTOOLS=1
