# Copy this file to `.env` and fill in your values (never commit `.env`).

# MAT-AI-OS backend — the single brain for chat. Must be running before MK1 can chat;
# there is no fallback to a direct LLM call if it's unreachable.
MAT_OS_URL=http://localhost:8000

# Still needed: OpenAI Whisper for voice-to-text (core/voice/speechToText.ts). This is
# the ONLY thing this key is used for now — chat itself goes through MAT-AI-OS above.
OPENAI_API_KEY=sk-your-key-here

# Optional: hint language for Whisper (ISO-639-1), e.g. Malay
# OPENAI_TRANSCRIBE_LANGUAGE=ms

# Optional: auto-open DevTools in dev
# MAT_AI_OPEN_DEVTOOLS=1

# core/desktop-mcp-server.ts's execute_terminal_command sandbox (real isolation for
# what used to be a raw child_process.exec() on the host). Requires Docker Desktop
# installed and the sandbox image built first:
#   docker build -f docker/sandbox.Dockerfile -t mat-ai-sandbox:latest .
# Leave these at their defaults unless you need to change the image name, where
# per-user workspace directories live, or the per-command timeout/resource limits.
# SANDBOX_IMAGE=mat-ai-sandbox:latest
# SANDBOX_WORKSPACE_ROOT=C:\Users\you\mat-ai-sandbox-workspaces
# SANDBOX_TIMEOUT_MS=120000
# SANDBOX_MEMORY=512m
# SANDBOX_CPUS=1

# Self-heal v2: prepare_repo_workspace clones/refreshes an offline copy of this path
# into the sandbox so the coding agent can propose and test a real fix against real
# source. Required for that feature to work — no hardcoded fallback (machine-specific
# path). Only ever read (git clone/fetch, never push); the sandboxed copy is disposable.
MAT_AI_OS_REPO_PATH=D:\MAT-AI-OS
